# Server Configuration
LOCAL_HOST=0.0.0.0
LOCAL_PORT=5050
FORCE_HTTPS=false
BEHIND_PROXY=true

# File Handling
TELEGRAM_MAX_FILE_SIZE=20971520
MAX_UPLOAD_SIZE=21474836480
ENABLE_COPY_MODE=true

# Hardware Acceleration
ENABLE_HARDWARE_ACCELERATION=true
PREFERRED_ENCODER=vaapi

# HLS Settings
HLS_SEGMENT_DURATION=4

# Bot Tokens (up to 8)
TELEGRAM_BOT_TOKEN_1=your_bot_1_token
TELEGRAM_BOT_TOKEN_2=your_bot_2_token
TELEGRAM_BOT_TOKEN_3=your_bot_3_token
TELEGRAM_BOT_TOKEN_4=your_bot_4_token
TELEGRAM_BOT_TOKEN_5=your_bot_5_token
TELEGRAM_BOT_TOKEN_6=your_bot_6_token
TELEGRAM_BOT_TOKEN_7=your_bot_7_token
TELEGRAM_BOT_TOKEN_8=your_bot_8_token

# Channel IDs (corresponding to each bot)
TELEGRAM_CHANNEL_ID_1=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_2=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_3=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_4=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_5=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_6=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_7=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_8=-100xxxxxxxxxx
