# Server Configuration
LOCAL_HOST=0.0.0.0
LOCAL_PORT=5050
FORCE_HTTPS=false
BEHIND_PROXY=true
CORS_ALLOWED_ORIGINS=                  # Comma-separated origins, or * for all

# Cloudflare Tunnel (set to false to disable)
CLOUDFLARED_ENABLED=true

# File Handling
TELEGRAM_MAX_FILE_SIZE=18874368        # 18MB per Telegram segment
MAX_UPLOAD_SIZE=107374182400           # 100GB max upload
UPLOAD_CHUNK_SIZE=10485760             # 10MB per upload chunk
SEGMENT_MAX_SIZE=18874368              # 18MB — size-based HLS segmentation (must be < TELEGRAM_MAX_FILE_SIZE)
SEGMENT_CACHE_SIZE_MB=200              # In-memory LRU segment cache (MB, 0=disabled)

# Hardware Acceleration
ENABLE_HARDWARE_ACCELERATION=true
# Encoder: vaapi (AMD/Intel via DRM), nvenc (NVIDIA), qsv (Intel Quick Sync)
PREFERRED_ENCODER=vaapi
# VAAPI device path (vaapi only). Leave empty to auto-detect — picks the
# highest /dev/dri/renderD* device, which is the dGPU on multi-GPU systems.
# Override if auto-detection picks the wrong GPU, e.g.:
#   VAAPI_DEVICE=/dev/dri/renderD128   # force Intel iGPU
#   VAAPI_DEVICE=/dev/dri/renderD129   # force AMD/Intel dGPU
VAAPI_DEVICE=
VIDEO_BITRATE=4M
AUDIO_BITRATE=128k

# HLS Settings
HLS_SEGMENT_DURATION=4                 # Used for audio segments; video uses size-based segmentation

# Adaptive Bitrate Streaming
ABR_ENABLED=true                       # CBR re-encoded tiers (same-res lower bitrate + 720p, 480p, 360p)
# ABR_TIERS=1080:10M,720:5M,480:2M,360:1200k
# TIER0_BITRATES=2160:60M,1080:30M,720:15M,480:5M
# TIER0_BITRATE_DEFAULT=15M

# Reliability / Cleanup
JOB_TIMEOUT_SECONDS=7200               # 2h max per job
PENDING_UPLOAD_TTL_SECONDS=86400       # 24h before stale uploads are cleaned
PENDING_UPLOAD_CLEANUP_INTERVAL_SECONDS=300
JOB_RETENTION_DAYS=0                   # Auto-delete completed jobs older than N days (0 = keep forever)
MAX_CONCURRENT_JOBS=1

# Rate Limiting (per IP)
UPLOAD_RATE_LIMIT_WINDOW=60            # seconds
UPLOAD_RATE_LIMIT_MAX_REQUESTS=100
MAX_PENDING_UPLOADS_PER_IP=5           # 0 = unlimited

# Upload Authentication (leave all empty to disable)
UPLOAD_API_KEY=
UPLOAD_BASIC_USER=
UPLOAD_BASIC_PASSWORD=

# Playback Authentication (HMAC-signed per-job tokens; leave empty to disable)
PLAYBACK_SECRET=

# Telegram Upload
UPLOAD_PARALLELISM=8                   # Max parallel upload workers across bots

# Bot Tokens (up to 8)
TELEGRAM_BOT_TOKEN_1=your_bot_1_token
TELEGRAM_BOT_TOKEN_2=your_bot_2_token
TELEGRAM_BOT_TOKEN_3=your_bot_3_token
TELEGRAM_BOT_TOKEN_4=your_bot_4_token
TELEGRAM_BOT_TOKEN_5=your_bot_5_token
TELEGRAM_BOT_TOKEN_6=your_bot_6_token
TELEGRAM_BOT_TOKEN_7=your_bot_7_token
TELEGRAM_BOT_TOKEN_8=your_bot_8_token

# Channel IDs (corresponding to each bot)
TELEGRAM_CHANNEL_ID_1=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_2=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_3=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_4=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_5=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_6=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_7=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID_8=-100xxxxxxxxxx
